# ============================================================
# Variáveis de Ambiente - Railway Deploy
# ============================================================
# Copie este arquivo para .env e preencha com seus valores

# ---------- BANCO DE DADOS (Railway PostgreSQL) ----------
# Railway vai criar automaticamente essas variáveis
# Você SÓ PRECISA copiar DATABASE_URL após criar o serviço PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/database"

# ---------- NODE ER AMBIENTE ----------
NODE_ENV="production"
PORT="3333"

# ---------- JWT (ALTERE ISSO!) ----------
JWT_SECRET="sua_chave_super_secreta_aqui_minimo_32_caracteres"
JWT_EXPIRES_IN="7d"

# ---------- FRONTEND URL ----------
# Railway vai gerar um URL automático para o frontend
FRONTEND_URL="https://seu-frontend.up.railway.app"
BACKEND_URL="https://seu-backend.up.railway.app"

# ---------- SERVIÇOS OPCIONAIS (por enquanto desativados) ----------
# Você pode ativar depois quando quiser escalar
# REDIS_URL=""
# KAFKA_BROKER=""
