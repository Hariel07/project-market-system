{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "railpack",
    "env": {
      "NIXPACKS_INSTALL_CMD": "npm install"
    }
  },
  "phases": {
    "install": {
      "cmds": [
        "npm install"
      ]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm start",
    "preDeployCommand": "npm run build && cd backend && npx prisma db push --accept-data-loss",
    "restartPolicyMaxRetries": 5
  }
}
