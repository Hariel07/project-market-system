{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "installCommand": "npm install"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm start",
    "preDeployCommand": "cd backend && npx prisma generate && npx prisma db push --accept-data-loss",
    "restartPolicyMaxRetries": 5
  }
}
