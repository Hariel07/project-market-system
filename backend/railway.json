{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm run start",
    "preDeployCommand": "npx prisma db push --accept-data-loss",
    "restartPolicyMaxRetries": 3
  }
}
