generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------

enum Role {
  ADMIN       // Nível 6: Plataforma Global
  DONO        // Nível 5: Proprietário do Comércio
  GERENTE     // Nível 4: Gerente da Loja
  ESTOQUE     // Nível 3: Repositor/Estoquista
  CAIXA       // Nível 2: Operador PDV
  GARCOM      // Nível 1: Atendimento
  ENTREGADOR  // Externo: Faz as entregas
  CLIENTE     // Externo: Compra pelo App
}

enum OrderStatus {
  PENDENTE
  PREPARANDO
  PRONTO
  SAIU_ENTREGA
  ENTREGUE
  CANCELADO
}

enum PaymentMethod {
  PIX
  CREDITO
  DEBITO
  DINHEIRO
}

enum TipoMovimentoCaixa {
  ABERTURA
  VENDA
  DINHEIRO_ENTRADA
  SANGRIA
  SUPRIMENTO
  DEVOLUCAO
  AJUSTE
  FECHAMENTO
}

// ----------------------------------------------------------------------
// MODELOS GLOBAIS
// ----------------------------------------------------------------------

model PlatformConfig {
  id                    String   @id @default("singleton")
  nomeApp               String   @default("Market System")
  assinaturaObrigatoria Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  nome         String   @unique
  slug         String   @unique
  preco        Float    @default(0)
  descricao    String?
  features     String[]
  maxItens     Int?
  maxPdvs      Int?
  destaque     Boolean  @default(false)
  ativo        Boolean  @default(true)
  ordem        Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  comercios    Commerce[]
}

// ----------------------------------------------------------------------
// GESTÃO DE IDENTIDADE (SSO)
// ----------------------------------------------------------------------

model Account {
  id        String   @id @default(uuid())
  cpf       String   @unique
  email     String   @unique
  senha     String   // Bcrypt hash
  telefone  String?
  ativo     Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  perfis    User[]
}

model User {
  id        String   @id @default(uuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  nome      String
  role      Role     @default(CLIENTE)
  ativo     Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  enderecos      Address[]
  comercioId     String?
  comercio       Commerce?  @relation(fields: [comercioId], references: [id])
  pedidosCliente Order[]    @relation("ClientePedidos")
  entregas       Delivery[] @relation("EntregadorDeliveries")
  chatsEntregador Chat[] @relation("EntregadorChats")
  chatsCliente   Chat[] @relation("ClienteChats")
  mensagensChat  ChatMessage[]
  ratingsEntregador Rating[] @relation("EntregadorRatings")
  ratingsCliente Rating[] @relation("ClienteRatings")
  notificacoes   Notification[]
  aberturasChaixa AberturaCaixa[]
  movimentosCaixa MovimentoCaixa[]
}

model Address {
  id              String   @id @default(uuid())
  userId          String?
  comercioId      String?
  
  logradouro      String
  numero          String?
  complemento     String?
  bairro          String?
  cidade          String?
  estado          String?
  cep             String?
  pontoReferencia String?
  
  rotulo          String   @default("CASA")
  icone           String   @default("🏠")
  
  lat             Float?
  lng             Float?
  
  isPrincipal     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comercio        Commerce? @relation(fields: [comercioId], references: [id], onDelete: Cascade)
}

model Commerce {
  id          String   @id @default(uuid())
  razaoSocial String
  nomeFantasia String
  cnpj        String   @unique
  segmento    String   // Mercado, Restaurante, Farmácia, etc.
  logoUrl     String?  
  ativo       Boolean  @default(false)
  planoAtual  String   @default("GRATIS")
  
  // Relação com plano de assinatura
  planoId     String?
  plano       SubscriptionPlan? @relation(fields: [planoId], references: [id])
  
  // Endereço e Configs Básicas
  taxaEntrega Float    @default(0.0)
  tempoMedio  String?  // Ex: "30-45 min"
  
  // Status de Operação
  isOpen             Boolean @default(true)
  horarioAtendimento String? // Ex: "Seg à Sex: 08:00h às 18:00h"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  enderecos   Address[]
  usuarios    User[]
  produtos    Product[]
  pedidos     Order[]
  categorias  Category[]
}

// ----------------------------------------------------------------------
// CATÁLOGO E PRODUTOS
// ----------------------------------------------------------------------

model Category {
  id         String   @id @default(uuid())
  nome       String
  icone      String?
  comercioId String
  comercio   Commerce @relation(fields: [comercioId], references: [id])
  produtos   Product[]
}

model Product {
  id            String   @id @default(uuid())
  comercioId    String
  categoriaId   String?
  
  nome          String
  descricao     String?
  precoVenda    Float
  precoPromocional Float?
  unidade       String   @default("UN") // UN, KG, L
  imagemUrl     String?
  
  estoque       Float    @default(0)
  isCombo       Boolean  @default(false)
  ativo         Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relações
  comercio      Commerce @relation(fields: [comercioId], references: [id])
  categoria     Category? @relation(fields: [categoriaId], references: [id])
  itensPedido   OrderItem[]
}

// ----------------------------------------------------------------------
// PEDIDOS E ENTREGAS
// ----------------------------------------------------------------------

model Order {
  id            String   @id @default(uuid())
  comercioId    String
  clienteId     String
  
  status        OrderStatus @default(PENDENTE)
  valorTotal    Float
  taxaEntrega   Float       @default(0.0)
  metodoPagto   PaymentMethod

  observacoes   String?
  enderecoEntrega String? // JSON ou string formatada
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relações
  comercio      Commerce @relation(fields: [comercioId], references: [id])
  cliente       User     @relation("ClientePedidos", fields: [clienteId], references: [id])
  itens         OrderItem[]
  entrega       Delivery?
}

model OrderItem {
  id          String   @id @default(uuid())
  pedidoId    String
  produtoId   String
  quantidade  Float
  precoUnitario Float
  
  createdAt   DateTime @default(now())
  
  pedido      Order    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto     Product  @relation(fields: [produtoId], references: [id])
}

model Delivery {
  id              String   @id @default(uuid())
  pedidoId        String   @unique
  entregadorId    String?
  
  status          String   @default("AGUARDANDO_COLETA")
  taxaRepasse     Float?
  assinatura      String?  // Base64 da assinatura do cliente na entrega

  coletadoEm      DateTime?
  entregueEm      DateTime?

  // Relações
  pedido          Order         @relation(fields: [pedidoId], references: [id])
  entregador      User?         @relation("EntregadorDeliveries", fields: [entregadorId], references: [id])
  gpsLogs         DeliveryGPS[]
  chat            Chat?
  rating          Rating?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DeliveryGPS {
  id          String   @id @default(uuid())
  deliveryId  String
  latitude    Float
  longitude   Float
  velocidade  Float?
  precisao    Float?
  timestamp   DateTime @default(now())

  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
}

// CHAT E COMUNICAÇÃO
model Chat {
  id                String   @id @default(uuid())
  entregaId         String   @unique
  entregadorId      String
  clienteId         String
  
  ultimaMensagem    String?
  ultimaAtividadeEm DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  entrega           Delivery @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  entregador        User     @relation("EntregadorChats", fields: [entregadorId], references: [id])
  cliente           User     @relation("ClienteChats", fields: [clienteId], references: [id])
  mensagens         ChatMessage[]
  
  @@index([entregadorId])
  @@index([clienteId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  chatId    String
  enviahoPor String   // "entregador" | "cliente"
  userId    String
  
  conteudo  String
  lido      Boolean  @default(false)
  
  createdAt DateTime @default(now())
  
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  usuario   User     @relation(fields: [userId], references: [id])
  
  @@index([chatId])
  @@index([userId])
}

// NOTIFICAÇÕES
model Notification {
  id        String   @id @default(uuid())
  userId    String
  tipo      String   // "nova_entrega", "perto_destino", "mensagem", "rating"
  titulo    String
  corpo     String
  icone     String?
  
  entregaId String?
  dados     String?  // JSON com dados adicionais
  
  lido      Boolean  @default(false)
  
  createdAt DateTime @default(now())
  
  usuario   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([lido])
}

// RATINGS E AVALIAÇÕES
model Rating {
  id            String   @id @default(uuid())
  entregaId     String   @unique
  entregadorId  String
  clienteId     String
  
  estrelas      Int      // 1-5
  comentario    String?
  respostaEntregador String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  entrega       Delivery @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  entregador    User     @relation("EntregadorRatings", fields: [entregadorId], references: [id])
  cliente       User     @relation("ClienteRatings", fields: [clienteId], references: [id])
}

// MOVIMENTO DE CAIXA
model AberturaCaixa {
  id              String   @id @default(uuid())
  comercioId      String
  pdvId           String?  // Opcional: se for PDV específico, senão é caixa geral
  
  status          String   @default("ABERTA")  // ABERTA, FECHADA
  saldoInicial    Float    @default(0.0)
  saldoFinal      Float?
  
  responsavelId   String
  responsavel     User     @relation(fields: [responsavelId], references: [id])
  
  dataAbertura    DateTime @default(now())
  dataFechamento  DateTime?
  
  observacoes     String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relações
  comercio        String   // Apenas para referência
  movimentos      MovimentoCaixa[]
  
  @@index([comercioId])
  @@index([status])
}

model MovimentoCaixa {
  id              String   @id @default(uuid())
  comercioId      String
  aberturaCaixaId String?
  pdvId           String?  // Opcional: PDV específico
  
  tipo            TipoMovimentoCaixa
  valor           Float    // Positivo = entrada, Negativo = saída
  descricao       String
  
  responsavelId   String
  responsavel     User     @relation(fields: [responsavelId], references: [id])
  
  referencia      String?  // ID relacionado (pedido, nf, etc)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relações
  aberturaCaixa   AberturaCaixa? @relation(fields: [aberturaCaixaId], references: [id], onDelete: SetNull)
  
  @@index([comercioId])
  @@index([tipo])
  @@index([aberturaCaixaId])
}

